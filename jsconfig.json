{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/lib/**/*.js"],
  "exclude": ["node_modules", "dist", "**/*.test.js", "**/*.test.jsx"]
}
